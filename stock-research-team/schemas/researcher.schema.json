{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Researcher Output",
  "type": "object",
  "required": ["agent_type", "ticker", "verdict", "conviction", "key_findings"],
  "properties": {
    "agent_type": {
      "type": "string",
      "enum": ["fundamental", "technical", "industry", "sentiment"]
    },
    "ticker": {"type": "string"},
    "verdict": {
      "type": "string",
      "enum": ["bullish", "neutral", "bearish"]
    },
    "conviction": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "key_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "evidence", "implication"],
        "properties": {
          "claim": {"type": "string"},
          "evidence": {"type": "string"},
          "implication": {"type": "string"}
        }
      },
      "minItems": 3
    },
    "data_quality_caveats": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
